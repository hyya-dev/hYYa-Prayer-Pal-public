{"surahNumber":26,"verses":[{"id":26001,"surahNumber":26,"verseNumber":1,"arabicText":" طسٓمٓ","pageNumber":367,"juzNumber":19},{"id":26002,"surahNumber":26,"verseNumber":2,"arabicText":"تِلْكَ ءَايَـٰتُ ٱلْكِتَـٰبِ ٱلْمُبِينِ","pageNumber":367,"juzNumber":19},{"id":26003,"surahNumber":26,"verseNumber":3,"arabicText":"لَعَلَّكَ بَـٰخِعٌ نَّفْسَكَ أَلَّا يَكُونُوا۟ مُؤْمِنِينَ","pageNumber":367,"juzNumber":19},{"id":26004,"surahNumber":26,"verseNumber":4,"arabicText":"إِن نَّشَأْ نُنَزِّلْ عَلَيْهِم مِّنَ ٱلسَّمَآءِ ءَايَةً فَظَلَّتْ أَعْنَـٰقُهُمْ لَهَا خَـٰضِعِينَ","pageNumber":367,"juzNumber":19},{"id":26005,"surahNumber":26,"verseNumber":5,"arabicText":"وَمَا يَأْتِيهِم مِّن ذِكْرٍ مِّنَ ٱلرَّحْمَـٰنِ مُحْدَثٍ إِلَّا كَانُوا۟ عَنْهُ مُعْرِضِينَ","pageNumber":367,"juzNumber":19},{"id":26006,"surahNumber":26,"verseNumber":6,"arabicText":"فَقَدْ كَذَّبُوا۟ فَسَيَأْتِيهِمْ أَنۢبَـٰٓؤُا۟ مَا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","pageNumber":367,"juzNumber":19},{"id":26007,"surahNumber":26,"verseNumber":7,"arabicText":"أَوَلَمْ يَرَوْا۟ إِلَى ٱلْأَرْضِ كَمْ أَنۢبَتْنَا فِيهَا مِن كُلِّ زَوْجٍ كَرِيمٍ","pageNumber":367,"juzNumber":19},{"id":26008,"surahNumber":26,"verseNumber":8,"arabicText":"إِنَّ فِى ذَٰلِكَ لَـَٔايَةً ۖ وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ","pageNumber":367,"juzNumber":19},{"id":26009,"surahNumber":26,"verseNumber":9,"arabicText":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ","pageNumber":367,"juzNumber":19},{"id":26010,"surahNumber":26,"verseNumber":10,"arabicText":"وَإِذْ نَادَىٰ رَبُّكَ مُوسَىٰٓ أَنِ ٱئْتِ ٱلْقَوْمَ ٱلظَّـٰلِمِينَ","pageNumber":367,"juzNumber":19},{"id":26011,"surahNumber":26,"verseNumber":11,"arabicText":"قَوْمَ فِرْعَوْنَ ۚ أَلَا يَتَّقُونَ","pageNumber":367,"juzNumber":19},{"id":26012,"surahNumber":26,"verseNumber":12,"arabicText":"قَالَ رَبِّ إِنِّىٓ أَخَافُ أَن يُكَذِّبُونِ","pageNumber":367,"juzNumber":19},{"id":26013,"surahNumber":26,"verseNumber":13,"arabicText":"وَيَضِيقُ صَدْرِى وَلَا يَنطَلِقُ لِسَانِى فَأَرْسِلْ إِلَىٰ هَـٰرُونَ","pageNumber":367,"juzNumber":19},{"id":26014,"surahNumber":26,"verseNumber":14,"arabicText":"وَلَهُمْ عَلَىَّ ذَنۢبٌ فَأَخَافُ أَن يَقْتُلُونِ","pageNumber":367,"juzNumber":19},{"id":26015,"surahNumber":26,"verseNumber":15,"arabicText":"قَالَ كَلَّا ۖ فَٱذْهَبَا بِـَٔايَـٰتِنَآ ۖ إِنَّا مَعَكُم مُّسْتَمِعُونَ","pageNumber":367,"juzNumber":19},{"id":26016,"surahNumber":26,"verseNumber":16,"arabicText":"فَأْتِيَا فِرْعَوْنَ فَقُولَآ إِنَّا رَسُولُ رَبِّ ٱلْعَـٰلَمِينَ","pageNumber":367,"juzNumber":19},{"id":26017,"surahNumber":26,"verseNumber":17,"arabicText":"أَنْ أَرْسِلْ مَعَنَا بَنِىٓ إِسْرَٰٓءِيلَ","pageNumber":367,"juzNumber":19},{"id":26018,"surahNumber":26,"verseNumber":18,"arabicText":"قَالَ أَلَمْ نُرَبِّكَ فِينَا وَلِيدًا وَلَبِثْتَ فِينَا مِنْ عُمُرِكَ سِنِينَ","pageNumber":367,"juzNumber":19},{"id":26019,"surahNumber":26,"verseNumber":19,"arabicText":"وَفَعَلْتَ فَعْلَتَكَ ٱلَّتِى فَعَلْتَ وَأَنتَ مِنَ ٱلْكَـٰفِرِينَ","pageNumber":367,"juzNumber":19},{"id":26020,"surahNumber":26,"verseNumber":20,"arabicText":"قَالَ فَعَلْتُهَآ إِذًا وَأَنَا۠ مِنَ ٱلضَّآلِّينَ","pageNumber":368,"juzNumber":19},{"id":26021,"surahNumber":26,"verseNumber":21,"arabicText":"فَفَرَرْتُ مِنكُمْ لَمَّا خِفْتُكُمْ فَوَهَبَ لِى رَبِّى حُكْمًا وَجَعَلَنِى مِنَ ٱلْمُرْسَلِينَ","pageNumber":368,"juzNumber":19},{"id":26022,"surahNumber":26,"verseNumber":22,"arabicText":"وَتِلْكَ نِعْمَةٌ تَمُنُّهَا عَلَىَّ أَنْ عَبَّدتَّ بَنِىٓ إِسْرَٰٓءِيلَ","pageNumber":368,"juzNumber":19},{"id":26023,"surahNumber":26,"verseNumber":23,"arabicText":"قَالَ فِرْعَوْنُ وَمَا رَبُّ ٱلْعَـٰلَمِينَ","pageNumber":368,"juzNumber":19},{"id":26024,"surahNumber":26,"verseNumber":24,"arabicText":"قَالَ رَبُّ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَآ ۖ إِن كُنتُم مُّوقِنِينَ","pageNumber":368,"juzNumber":19},{"id":26025,"surahNumber":26,"verseNumber":25,"arabicText":"قَالَ لِمَنْ حَوْلَهُۥٓ أَلَا تَسْتَمِعُونَ","pageNumber":368,"juzNumber":19},{"id":26026,"surahNumber":26,"verseNumber":26,"arabicText":"قَالَ رَبُّكُمْ وَرَبُّ ءَابَآئِكُمُ ٱلْأَوَّلِينَ","pageNumber":368,"juzNumber":19},{"id":26027,"surahNumber":26,"verseNumber":27,"arabicText":"قَالَ إِنَّ رَسُولَكُمُ ٱلَّذِىٓ أُرْسِلَ إِلَيْكُمْ لَمَجْنُونٌ","pageNumber":368,"juzNumber":19},{"id":26028,"surahNumber":26,"verseNumber":28,"arabicText":"قَالَ رَبُّ ٱلْمَشْرِقِ وَٱلْمَغْرِبِ وَمَا بَيْنَهُمَآ ۖ إِن كُنتُمْ تَعْقِلُونَ","pageNumber":368,"juzNumber":19},{"id":26029,"surahNumber":26,"verseNumber":29,"arabicText":"قَالَ لَئِنِ ٱتَّخَذْتَ إِلَـٰهًا غَيْرِى لَأَجْعَلَنَّكَ مِنَ ٱلْمَسْجُونِينَ","pageNumber":368,"juzNumber":19},{"id":26030,"surahNumber":26,"verseNumber":30,"arabicText":"قَالَ أَوَلَوْ جِئْتُكَ بِشَىْءٍ مُّبِينٍ","pageNumber":368,"juzNumber":19},{"id":26031,"surahNumber":26,"verseNumber":31,"arabicText":"قَالَ فَأْتِ بِهِۦٓ إِن كُنتَ مِنَ ٱلصَّـٰدِقِينَ","pageNumber":368,"juzNumber":19},{"id":26032,"surahNumber":26,"verseNumber":32,"arabicText":"فَأَلْقَىٰ عَصَاهُ فَإِذَا هِىَ ثُعْبَانٌ مُّبِينٌ","pageNumber":368,"juzNumber":19},{"id":26033,"surahNumber":26,"verseNumber":33,"arabicText":"وَنَزَعَ يَدَهُۥ فَإِذَا هِىَ بَيْضَآءُ لِلنَّـٰظِرِينَ","pageNumber":368,"juzNumber":19},{"id":26034,"surahNumber":26,"verseNumber":34,"arabicText":"قَالَ لِلْمَلَإِ حَوْلَهُۥٓ إِنَّ هَـٰذَا لَسَـٰحِرٌ عَلِيمٌ","pageNumber":368,"juzNumber":19},{"id":26035,"surahNumber":26,"verseNumber":35,"arabicText":"يُرِيدُ أَن يُخْرِجَكُم مِّنْ أَرْضِكُم بِسِحْرِهِۦ فَمَاذَا تَأْمُرُونَ","pageNumber":368,"juzNumber":19},{"id":26036,"surahNumber":26,"verseNumber":36,"arabicText":"قَالُوٓا۟ أَرْجِهْ وَأَخَاهُ وَٱبْعَثْ فِى ٱلْمَدَآئِنِ حَـٰشِرِينَ","pageNumber":368,"juzNumber":19},{"id":26037,"surahNumber":26,"verseNumber":37,"arabicText":"يَأْتُوكَ بِكُلِّ سَحَّارٍ عَلِيمٍ","pageNumber":368,"juzNumber":19},{"id":26038,"surahNumber":26,"verseNumber":38,"arabicText":"فَجُمِعَ ٱلسَّحَرَةُ لِمِيقَـٰتِ يَوْمٍ مَّعْلُومٍ","pageNumber":368,"juzNumber":19},{"id":26039,"surahNumber":26,"verseNumber":39,"arabicText":"وَقِيلَ لِلنَّاسِ هَلْ أَنتُم مُّجْتَمِعُونَ","pageNumber":368,"juzNumber":19},{"id":26040,"surahNumber":26,"verseNumber":40,"arabicText":"لَعَلَّنَا نَتَّبِعُ ٱلسَّحَرَةَ إِن كَانُوا۟ هُمُ ٱلْغَـٰلِبِينَ","pageNumber":369,"juzNumber":19},{"id":26041,"surahNumber":26,"verseNumber":41,"arabicText":"فَلَمَّا جَآءَ ٱلسَّحَرَةُ قَالُوا۟ لِفِرْعَوْنَ أَئِنَّ لَنَا لَأَجْرًا إِن كُنَّا نَحْنُ ٱلْغَـٰلِبِينَ","pageNumber":369,"juzNumber":19},{"id":26042,"surahNumber":26,"verseNumber":42,"arabicText":"قَالَ نَعَمْ وَإِنَّكُمْ إِذًا لَّمِنَ ٱلْمُقَرَّبِينَ","pageNumber":369,"juzNumber":19},{"id":26043,"surahNumber":26,"verseNumber":43,"arabicText":"قَالَ لَهُم مُّوسَىٰٓ أَلْقُوا۟ مَآ أَنتُم مُّلْقُونَ","pageNumber":369,"juzNumber":19},{"id":26044,"surahNumber":26,"verseNumber":44,"arabicText":"فَأَلْقَوْا۟ حِبَالَهُمْ وَعِصِيَّهُمْ وَقَالُوا۟ بِعِزَّةِ فِرْعَوْنَ إِنَّا لَنَحْنُ ٱلْغَـٰلِبُونَ","pageNumber":369,"juzNumber":19},{"id":26045,"surahNumber":26,"verseNumber":45,"arabicText":"فَأَلْقَىٰ مُوسَىٰ عَصَاهُ فَإِذَا هِىَ تَلْقَفُ مَا يَأْفِكُونَ","pageNumber":369,"juzNumber":19},{"id":26046,"surahNumber":26,"verseNumber":46,"arabicText":"فَأُلْقِىَ ٱلسَّحَرَةُ سَـٰجِدِينَ","pageNumber":369,"juzNumber":19},{"id":26047,"surahNumber":26,"verseNumber":47,"arabicText":"قَالُوٓا۟ ءَامَنَّا بِرَبِّ ٱلْعَـٰلَمِينَ","pageNumber":369,"juzNumber":19},{"id":26048,"surahNumber":26,"verseNumber":48,"arabicText":"رَبِّ مُوسَىٰ وَهَـٰرُونَ","pageNumber":369,"juzNumber":19},{"id":26049,"surahNumber":26,"verseNumber":49,"arabicText":"قَالَ ءَامَنتُمْ لَهُۥ قَبْلَ أَنْ ءَاذَنَ لَكُمْ ۖ إِنَّهُۥ لَكَبِيرُكُمُ ٱلَّذِى عَلَّمَكُمُ ٱلسِّحْرَ فَلَسَوْفَ تَعْلَمُونَ ۚ لَأُقَطِّعَنَّ أَيْدِيَكُمْ وَأَرْجُلَكُم مِّنْ خِلَـٰفٍ وَلَأُصَلِّبَنَّكُمْ أَجْمَعِينَ","pageNumber":369,"juzNumber":19},{"id":26050,"surahNumber":26,"verseNumber":50,"arabicText":"قَالُوا۟ لَا ضَيْرَ ۖ إِنَّآ إِلَىٰ رَبِّنَا مُنقَلِبُونَ","pageNumber":369,"juzNumber":19},{"id":26051,"surahNumber":26,"verseNumber":51,"arabicText":"