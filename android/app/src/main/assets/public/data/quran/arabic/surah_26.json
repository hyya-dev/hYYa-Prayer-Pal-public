370,"juzNumber":19},{"id":26065,"surahNumber":26,"verseNumber":65,"arabicText":"وَأَنجَيْنَا مُوسَىٰ وَمَن مَّعَهُۥٓ أَجْمَعِينَ","pageNumber":370,"juzNumber":19},{"id":26066,"surahNumber":26,"verseNumber":66,"arabicText":"ثُمَّ أَغْرَقْنَا ٱلْـَٔاخَرِينَ","pageNumber":370,"juzNumber":19},{"id":26067,"surahNumber":26,"verseNumber":67,"arabicText":"إِنَّ فِى ذَٰلِكَ لَـَٔايَةً ۖ وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ","pageNumber":370,"juzNumber":19},{"id":26068,"surahNumber":26,"verseNumber":68,"arabicText":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ","pageNumber":370,"juzNumber":19},{"id":26069,"surahNumber":26,"verseNumber":69,"arabicText":"وَٱتْلُ عَلَيْهِمْ نَبَأَ إِبْرَٰهِيمَ","pageNumber":370,"juzNumber":19},{"id":26070,"surahNumber":26,"verseNumber":70,"arabicText":"إِذْ قَالَ لِأَبِيهِ وَقَوْمِهِۦ مَا تَعْبُدُونَ","pageNumber":370,"juzNumber":19},{"id":26071,"surahNumber":26,"verseNumber":71,"arabicText":"قَالُوا۟ نَعْبُدُ أَصْنَامًا فَنَظَلُّ لَهَا عَـٰكِفِينَ","pageNumber":370,"juzNumber":19},{"id":26072,"surahNumber":26,"verseNumber":72,"arabicText":"قَالَ هَلْ يَسْمَعُونَكُمْ إِذْ تَدْعُونَ","pageNumber":370,"juzNumber":19},{"id":26073,"surahNumber":26,"verseNumber":73,"arabicText":"أَوْ يَنفَعُونَكُمْ أَوْ يَضُرُّونَ","pageNumber":370,"juzNumber":19},{"id":26074,"surahNumber":26,"verseNumber":74,"arabicText":"قَالُوا۟ بَلْ وَجَدْنَآ ءَابَآءَنَا كَذَٰلِكَ يَفْعَلُونَ","pageNumber":370,"juzNumber":19},{"id":26075,"surahNumber":26,"verseNumber":75,"arabicText":"قَالَ أَفَرَءَيْتُم مَّا كُنتُمْ تَعْبُدُونَ","pageNumber":370,"juzNumber":19},{"id":26076,"surahNumber":26,"verseNumber":76,"arabicText":"أَنتُمْ وَءَابَآؤُكُمُ ٱلْأَقْدَمُونَ","pageNumber":370,"juzNumber":19},{"id":26077,"surahNumber":26,"verseNumber":77,"arabicText":"فَإِنَّهُمْ عَدُوٌّ لِّىٓ إِلَّا رَبَّ ٱلْعَـٰلَمِينَ","pageNumber":370,"juzNumber":19},{"id":26078,"surahNumber":26,"verseNumber":78,"arabicText":"ٱلَّذِى خَلَقَنِى فَهُوَ يَهْدِينِ","pageNumber":370,"juzNumber":19},{"id":26079,"