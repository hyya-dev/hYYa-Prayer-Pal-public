{"surahNumber":111,"verses":[{"id":111001,"surahNumber":111,"verseNumber":1,"arabicText":" تَبَّتْ يَدَآ أَبِى لَهَبٍ وَتَبَّ","pageNumber":603,"juzNumber":30},{"id":111002,"surahNumber":111,"verseNumber":2,"arabicText":"مَآ أَغْنَىٰ عَنْهُ مَالُهُۥ وَمَا كَسَبَ","pageNumber":603,"juzNumber":30},{"id":111003,"surahNumber":111,"verseNumber":3,"arabicText":"سَيَصْلَىٰ نَارًا ذَاتَ لَهَبٍ","pageNumber":603,"juzNumber":30},{"id":111004,"surahNumber":111,"verseNumber":4,"arabicText":"وَٱمْرَأَتُهُۥ حَمَّالَةَ ٱلْحَطَبِ","pageNumber":603,"juzNumber":30},{"id":111005,"surahNumber":111,"verseNumber":5,"arabicText":"فِى جِيدِهَا حَبْلٌ مِّن مَّسَدٍۭ","pageNumber":603,"juzNumber":30}]}