{"surahNumber":97,"verses":[{"id":97001,"surahNumber":97,"verseNumber":1,"arabicText":"إِنَّآ أَنزَلْنَـٰهُ فِى لَيْلَةِ ٱلْقَدْرِ","pageNumber":598,"juzNumber":30},{"id":97002,"surahNumber":97,"verseNumber":2,"arabicText":"وَمَآ أَدْرَىٰكَ مَا لَيْلَةُ ٱلْقَدْرِ","pageNumber":598,"juzNumber":30},{"id":97003,"surahNumber":97,"verseNumber":3,"arabicText":"لَيْلَةُ ٱلْقَدْرِ خَيْرٌ مِّنْ أَلْفِ شَهْرٍ","pageNumber":598,"juzNumber":30},{"id":97004,"surahNumber":97,"verseNumber":4,"arabicText":"تَنَزَّلُ ٱلْمَلَـٰٓئِكَةُ وَٱلرُّوحُ فِيهَا بِإِذْنِ رَبِّهِم مِّن كُلِّ أَمْرٍ","pageNumber":598,"juzNumber":30},{"id":97005,"surahNumber":97,"verseNumber":5,"arabicText":"سَلَـٰمٌ هِىَ حَتَّىٰ مَطْلَعِ ٱلْفَجْرِ","pageNumber":598,"juzNumber":30}]}