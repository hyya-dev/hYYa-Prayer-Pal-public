{"surahNumber":68,"verses":[{"id":68001,"surahNumber":68,"verseNumber":1,"arabicText":" نٓ ۚ وَٱلْقَلَمِ وَمَا يَسْطُرُونَ","pageNumber":564,"juzNumber":29},{"id":68002,"surahNumber":68,"verseNumber":2,"arabicText":"مَآ أَنتَ بِنِعْمَةِ رَبِّكَ بِمَجْنُونٍ","pageNumber":564,"juzNumber":29},{"id":68003,"surahNumber":68,"verseNumber":3,"arabicText":"وَإِنَّ لَكَ لَأَجْرًا غَيْرَ مَمْنُونٍ","pageNumber":564,"juzNumber":29},{"id":68004,"surahNumber":68,"verseNumber":4,"arabicText":"وَإِنَّكَ لَعَلَىٰ خُلُقٍ عَظِيمٍ","pageNumber":564,"juzNumber":29},{"id":68005,"surahNumber":68,"verseNumber":5,"arabicText":"فَسَتُبْصِرُ وَيُبْصِرُونَ","pageNumber":564,"juzNumber":29},{"id":68006,"surahNumber":68,"verseNumber":6,"arabicText":"بِأَييِّكُمُ ٱلْمَفْتُونُ","pageNumber":564,"juzNumber":29},{"id":68007,"surahNumber":68,"verseNumber":7,"arabicText":"إِنَّ رَبَّكَ هُوَ أَعْلَمُ بِمَن ضَلَّ عَن سَبِيلِهِۦ وَهُوَ أَعْلَمُ بِٱلْمُهْتَدِينَ","pageNumber":564,"juzNumber":29},{"id":68008,"surahNumber":68,"verseNumber":8,"arabicText":"فَلَا تُطِعِ ٱلْمُكَذِّبِينَ","pageNumber":564,"juzNumber":29},{"id":68009,"surahNumber":68,"verseNumber":9,"arabicText":"وَدُّوا۟ لَوْ تُدْهِنُ فَيُدْهِنُونَ","pageNumber":564,"juzNumber":29},{"id":68010,"surahNumber":68,"verseNumber":10,"arabicText":"وَلَا تُطِعْ كُلَّ حَلَّافٍ مَّهِينٍ","pageNumber":564,"juzNumber":29},{"id":68011,"surahNumber":68,"verseNumber":11,"arabicText":"هَمَّازٍ مَّشَّآءٍۭ بِنَمِيمٍ","pageNumber":564,"juzNumber":29},{"id":68012,"surahNumber":68,"verseNumber":12,"arabicText":"مَّنَّاعٍ لِّلْخَيْرِ مُعْتَدٍ أَثِيمٍ","pageNumber":564,"juzNumber":29},{"id":68013,"surahNumber":68,"verseNumber":13,"arabicText":"عُتُلٍّۭ بَعْدَ ذَٰلِكَ زَنِيمٍ","pageNumber":564,"juzNumber":29},{"id":68014,"surahNumber":68,"verseNumber":14,"arabicText":"أَن كَانَ ذَا مَالٍ وَبَنِينَ","pageNumber":564,"juzNumber":29},{"id":68015,"surahNumber":68,"verseNumber":15,"arabicText":"إِذَا تُتْلَىٰ عَلَيْهِ ءَايَـٰتُنَا قَالَ أَسَـٰطِيرُ ٱلْأَوَّلِينَ","pageNumber":564,"juzNumber":29},{"id":68016,"surahNumber":68,"verseNumber":16,"arabicText":"سَنَسِمُهُۥ عَلَى ٱلْخُرْطُومِ","pageNumber":565,"juzNumber":29},{"id":68017,"surahNumber":68,"verseNumber":17,"arabicText":"إِنَّا بَلَوْنَـٰهُمْ كَمَا بَلَوْنَآ أَصْحَـٰبَ ٱلْجَنَّةِ إِذْ أَقْسَمُوا۟ لَيَصْرِمُنَّهَا مُصْبِحِينَ","pageNumber":565,"juzNumber":29},{"id":68018,"surahNumber":68,"verseNumber":18,"arabicText":"وَلَا يَسْتَثْنُونَ","pageNumber":565,"juzNumber":29},{"id":68019,"surahNumber":68,"verseNumber":19,"arabicText":"فَطَافَ عَلَيْهَا طَآئِفٌ مِّن رَّبِّكَ وَهُمْ نَآئِمُونَ","pageNumber":565,"juzNumber":29},{"id":68020,"surahNumber":68,"verseNumber":20,"arabicText":"فَأَصْبَحَتْ كَٱلصَّرِيمِ","pageNumber":565,"juzNumber":29},{"id":68021,"surahNumber":68,"verseNumber":21,"arabicText":"فَتَنَادَوْا۟ مُصْبِحِينَ","pageNumber":565,"juzNumber":29},{"id":68022,"surahNumber":68,"verseNumber":22,"arabicText":"أَنِ ٱغْدُوا۟ عَلَىٰ حَرْثِكُمْ إِن كُنتُمْ صَـٰرِمِينَ","pageNumber":565,"juzNumber":29},{"id":68023,"surahNumber":68,"verseNumber":23,"arabicText":"فَٱنطَلَقُوا۟ وَهُمْ يَتَخَـٰفَتُونَ","pageNumber":565,"juzNumber":29},{"id":68024,"surahNumber":68,"verseNumber":24,"arabicText":"أَن لَّا يَدْخُلَنَّهَا ٱلْيَوْمَ عَلَيْكُم مِّسْكِينٌ","pageNumber":565,"juzNumber":29},{"id":68025,"surahNumber":68,"verseNumber":25,"arabicText":"وَغَدَوْا۟ عَلَىٰ حَرْدٍ قَـٰدِرِينَ","pageNumber":565,"juzNumber":29},{"id":68026,"surahNumber":68,"verseNumber":26,"arabicText":"فَلَمَّا رَأَوْهَا قَالُوٓا۟ إِنَّا لَضَآلُّونَ","pageNumber":565,"juzNumber":29},{"id":68027,"surahNumber":68,"verseNumber":27,"arabicText":"بَلْ نَحْنُ مَحْرُومُونَ","pageNumber":565,"juzNumber":29},{"id":68028,"surahNumber":68,"verseNumber":28,"arabicText":"قَالَ أَوْسَطُهُمْ أَلَمْ أَقُل لَّكُمْ لَوْلَا تُسَبِّحُونَ","pageNumber":565,"juzNumber":29},{"id":68029,"surahNumber":68,"verseNumber":29,"arabicText":"قَالُوا۟ سُبْحَـٰنَ رَبِّنَآ إِنَّا كُنَّا ظَـٰلِمِينَ","pageNumber":565,"juzNumber":29},{"id":68030,"surahNumber":68,"verseNumber":30,"arabicText":"فَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَلَـٰوَمُونَ","pageNumber":565,"juzNumber":29},{"id":68031,"surahNumber":68,"verseNumber":31,"arabicText":"قَالُوا۟ يَـٰوَيْلَنَآ إِنَّا كُنَّا طَـٰغِينَ","pageNumber":565,"juzNumber":29},{"id":68032,"surahNumber":68,"verseNumber":32,"arabicText":"عَسَىٰ رَبُّنَآ أَن يُبْدِلَنَا خَيْرًا مِّنْهَآ إِنَّآ إِلَىٰ رَبِّنَا رَٰغِبُونَ","pageNumber":565,"juzNumber":29},{"id":68033,"surahNumber":68,"verseNumber":33,"arabicText":"كَذَٰلِكَ ٱلْعَذَابُ ۖ وَلَعَذَابُ ٱلْـَٔاخِرَةِ أَكْبَرُ ۚ لَوْ كَانُوا۟ يَعْلَمُونَ","pageNumber":565,"juzNumber":29},{"id":68034,"surahNumber":68,"verseNumber":34,"arabicText":"إِنَّ لِلْمُتَّقِينَ عِندَ رَبِّهِمْ جَنَّـٰتِ ٱلنَّعِيمِ","pageNumber":565,"juzNumber":29},{"id":68035,"surahNumber":68,"verseNumber":35,"arabicText":"أَفَنَجْعَلُ ٱلْمُسْلِمِينَ كَٱلْمُجْرِمِينَ","pageNumber":565,"juzNumber":29},{"id":68036,"surahNumber":68,"verseNumber":36,"arabicText":"مَا لَكُمْ كَيْفَ تَحْكُمُونَ","pageNumber":565,"juzNumber":29},{"id":68037,"surahNumber":68,"verseNumber":37,"arabicText":"أَمْ لَكُمْ كِتَـٰبٌ فِيهِ تَدْرُسُونَ","pageNumber":565,"juzNumber":29},{"id":68038,"surahNumber":68,"verseNumber":38,"arabicText":"إِنَّ لَكُمْ فِيهِ لَمَا تَخَيَّرُونَ","pageNumber":565,"juzNumber":29},{"id":68039,"surahNumber":68,"verseNumber":39,"arabicText":"أَمْ لَكُمْ أَيْمَـٰنٌ عَلَيْنَا بَـٰلِغَةٌ إِلَىٰ يَوْمِ ٱلْقِيَـٰمَةِ ۙ إِنَّ لَكُمْ لَمَا تَحْكُمُونَ","pageNumber":565,"juzNumber":29},{"id":68040,"surahNumber":68,"verseNumber":40,"arabicText":"سَلْهُمْ أَيُّهُم بِذَٰلِكَ زَعِيمٌ","pageNumber":565,"juzNumber":29},{"id":68041,"surahNumber":68,"verseNumber":41,"arabicText":"أَمْ لَهُمْ شُرَكَآءُ فَلْيَأْتُوا۟ بِشُرَكَآئِهِمْ إِن كَانُوا۟ صَـٰدِقِينَ","pageNumber":565,"juzNumber":29},{"id":68042,"surahNumber":68,"verseNumber":42,"arabicText":"يَوْمَ يُكْشَفُ عَن سَاقٍ وَيُدْعَوْنَ إِلَى ٱلسُّجُودِ فَلَا يَسْتَطِيعُونَ","pageNumber":565,"juzNumber":29},{"id":68043,"surahNumber":68,"verseNumber":43,"arabicText":"خَـٰشِعَةً أَبْصَـٰرُهُمْ تَرْهَقُهُمْ ذِلَّةٌ ۖ وَقَدْ كَانُوا۟ يُدْعَوْنَ إِلَى ٱلسُّجُودِ وَهُمْ سَـٰلِمُونَ","pageNumber":566,"juzNumber":29},{"id":68044,"surahNumber":68,"verseNumber":44,"arabicText":"فَذَرْنِى وَمَن يُكَذِّبُ بِهَـٰذَا ٱلْحَدِيثِ ۖ سَنَسْتَدْرِجُهُم مِّنْ حَيْثُ لَا يَعْلَمُونَ","pageNumber":566,"juzNumber":29},{"id":68045,"surahNumber":68,"verseNumber":45,"arabicText":"وَأُمْلِى لَهُمْ ۚ إِنَّ كَيْدِى مَتِينٌ","pageNumber":566,"juzNumber":29},{"id":68046,"surahNumber":68,"verseNumber":46,"arabicText":"أَمْ تَسْـَٔلُهُمْ أَجْرًا فَهُم مِّن مَّغْرَمٍ مُّثْقَلُونَ","pageNumber":566,"juzNumber":29},{"id":68047,"surahNumber":68,"verseNumber":47,"arabicText":"أَمْ عِندَهُمُ ٱلْغَيْبُ فَهُمْ يَكْتُبُونَ","pageNumber":566,"juzNumber":29},{"id":68048,"surahNumber":68,"verseNumber":48,"arabicText":"فَٱصْبِرْ لِحُكْمِ رَبِّكَ وَلَا تَكُن كَصَاحِبِ ٱلْحُوتِ إِذْ نَادَىٰ وَهُوَ مَكْظُومٌ","pageNumber":566,"juzNumber":29},{"id":68049,"surahNumber":68,"verseNumber":49,"arabicText":"لَّوْلَآ أَن تَدَٰرَكَهُۥ نِعْمَةٌ مِّن رَّبِّهِۦ لَنُبِذَ بِٱلْعَرَآءِ وَهُوَ مَذْمُومٌ","pageNumber":566,"juzNumber":29},{"id":68050,"surahNumber":68,"verseNumber":50,"arabicText":"فَٱجْتَبَـٰهُ رَبُّهُۥ فَجَعَلَهُۥ مِنَ ٱلصَّـٰلِحِينَ","pageNumber":566,"juzNumber":29},{"id":68051,"surahNumber":68,"verseNumber":51,"arabicText":"وَإِن يَكَادُ ٱلَّذِينَ كَفَرُوا۟ لَيُزْلِقُونَكَ بِأَبْصَـٰرِهِمْ لَمَّا سَمِعُوا۟ ٱلذِّكْرَ وَيَقُولُونَ إِنَّهُۥ لَمَجْنُونٌ","pageNumber":566,"juzNumber":29},{"id":68052,"surahNumber":68,"verseNumber":52,"arabicText":"وَمَا هُوَ إِلَّا ذِكْرٌ لِّلْعَـٰلَمِينَ","pageNumber":566,"juzNumber":29}]}