{"surahNumber":84,"verses":[{"id":84001,"surahNumber":84,"verseNumber":1,"arabicText":" إِذَا ٱلسَّمَآءُ ٱنشَقَّتْ","pageNumber":589,"juzNumber":30},{"id":84002,"surahNumber":84,"verseNumber":2,"arabicText":"وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ","pageNumber":589,"juzNumber":30},{"id":84003,"surahNumber":84,"verseNumber":3,"arabicText":"وَإِذَا ٱلْأَرْضُ مُدَّتْ","pageNumber":589,"juzNumber":30},{"id":84004,"surahNumber":84,"verseNumber":4,"arabicText":"وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ","pageNumber":589,"juzNumber":30},{"id":84005,"surahNumber":84,"verseNumber":5,"arabicText":"وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ","pageNumber":589,"juzNumber":30},{"id":84006,"surahNumber":84,"verseNumber":6,"arabicText":"يَـٰٓأَيُّهَا ٱلْإِنسَـٰنُ إِنَّكَ كَادِحٌ إِلَىٰ رَبِّكَ كَدْحًا فَمُلَـٰقِيهِ","pageNumber":589,"juzNumber":30},{"id":84007,"surahNumber":84,"verseNumber":7,"arabicText":"فَأَمَّا مَنْ أُوتِىَ كِتَـٰبَهُۥ بِيَمِينِهِۦ","pageNumber":589,"juzNumber":30},{"id":84008,"surahNumber":84,"verseNumber":8,"arabicText":"فَسَوْفَ يُحَاسَبُ حِسَابًا يَسِيرًا","pageNumber":589,"juzNumber":30},{"id":84009,"surahNumber":84,"verseNumber":9,"arabicText":"وَيَنقَلِبُ إِلَىٰٓ أَهْلِهِۦ مَسْرُورًا","pageNumber":589,"juzNumber":30},{"id":84010,"surahNumber":84,"verseNumber":10,"arabicText":"وَأَمَّا مَنْ أُوتِىَ كِتَـٰبَهُۥ وَرَآءَ ظَهْرِهِۦ","pageNumber":589,"juzNumber":30},{"id":84011,"surahNumber":84,"verseNumber":11,"arabicText":"فَسَوْفَ يَدْعُوا۟ ثُبُورًا","pageNumber":589,"juzNumber":30},{"id":84012,"surahNumber":84,"verseNumber":12,"arabicText":"وَيَصْلَىٰ سَعِيرًا","pageNumber":589,"juzNumber":30},{"id":84013,"surahNumber":84,"verseNumber":13,"arabicText":"إِنَّهُۥ كَانَ فِىٓ أَهْلِهِۦ مَسْرُورًا","pageNumber":589,"juzNumber":30},{"id":84014,"surahNumber":84,"verseNumber":14,"arabicText":"إِنَّهُۥ ظَنَّ أَن لَّن يَحُورَ","pageNumber":589,"juzNumber":30},{"id":84015,"surahNumber":84,"verseNumber":15,"arabicText":"بَلَىٰٓ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِيرًا","pageNumber":589,"juzNumber"