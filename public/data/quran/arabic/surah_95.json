{"surahNumber":95,"verses":[{"id":95001,"surahNumber":95,"verseNumber":1,"arabicText":"وَٱلتِّينِ وَٱلزَّيْتُونِ","pageNumber":597,"juzNumber":30},{"id":95002,"surahNumber":95,"verseNumber":2,"arabicText":"وَطُورِ سِينِينَ","pageNumber":597,"juzNumber":30},{"id":95003,"surahNumber":95,"verseNumber":3,"arabicText":"وَهَـٰذَا ٱلْبَلَدِ ٱلْأَمِينِ","pageNumber":597,"juzNumber":30},{"id":95004,"surahNumber":95,"verseNumber":4,"arabicText":"لَقَدْ خَلَقْنَا ٱلْإِنسَـٰنَ فِىٓ أَحْسَنِ تَقْوِيمٍ","pageNumber":597,"juzNumber":30},{"id":95005,"surahNumber":95,"verseNumber":5,"arabicText":"ثُمَّ رَدَدْنَـٰهُ أَسْفَلَ سَـٰفِلِينَ","pageNumber":597,"juzNumber":30},{"id":95006,"surahNumber":95,"verseNumber":6,"arabicText":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ فَلَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍ","pageNumber":597,"juzNumber":30},{"id":95007,"surahNumber":95,"verseNumber":7,"arabicText":"فَمَا يُكَذِّبُكَ بَعْدُ بِٱلدِّينِ","pageNumber":597,"juzNumber":30},{"id":95008,"surahNumber":95,"verseNumber":8,"arabicText":"أَلَيْسَ ٱللَّهُ بِأَحْكَمِ ٱلْحَـٰكِمِينَ","pageNumber":597,"juzNumber":30}]}