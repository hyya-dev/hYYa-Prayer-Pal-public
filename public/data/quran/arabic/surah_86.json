{"surahNumber":86,"verses":[{"id":86001,"surahNumber":86,"verseNumber":1,"arabicText":" وَٱلسَّمَآءِ وَٱلطَّارِقِ","pageNumber":591,"juzNumber":30},{"id":86002,"surahNumber":86,"verseNumber":2,"arabicText":"وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ","pageNumber":591,"juzNumber":30},{"id":86003,"surahNumber":86,"verseNumber":3,"arabicText":"ٱلنَّجْمُ ٱلثَّاقِبُ","pageNumber":591,"juzNumber":30},{"id":86004,"surahNumber":86,"verseNumber":4,"arabicText":"إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ","pageNumber":591,"juzNumber":30},{"id":86005,"surahNumber":86,"verseNumber":5,"arabicText":"فَلْيَنظُرِ ٱلْإِنسَـٰنُ مِمَّ خُلِقَ","pageNumber":591,"juzNumber":30},{"id":86006,"surahNumber":86,"verseNumber":6,"arabicText":"خُلِقَ مِن مَّآءٍ دَافِقٍ","pageNumber":591,"juzNumber":30},{"id":86007,"surahNumber":86,"verseNumber":7,"arabicText":"يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ","pageNumber":591,"juzNumber":30},{"id":86008,"surahNumber":86,"verseNumber":8,"arabicText":"إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌ","pageNumber":591,"juzNumber":30},{"id":86009,"surahNumber":86,"verseNumber":9,"arabicText":"يَوْمَ تُبْلَى ٱلسَّرَآئِرُ","pageNumber":591,"juzNumber":30},{"id":86010,"surahNumber":86,"verseNumber":10,"arabicText":"فَمَا لَهُۥ مِن قُوَّةٍ وَلَا نَاصِرٍ","pageNumber":591,"juzNumber":30},{"id":86011,"surahNumber":86,"verseNumber":11,"arabicText":"وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ","pageNumber":591,"juzNumber":30},{"id":86012,"surahNumber":86,"verseNumber":12,"arabicText":"وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ","pageNumber":591,"juzNumber":30},{"id":86013,"surahNumber":86,"verseNumber":13,"arabicText":"إِنَّهُۥ لَقَوْلٌ فَصْلٌ","pageNumber":591,"juzNumber":30},{"id":86014,"surahNumber":86,"verseNumber":14,"arabicText":"وَمَا هُوَ بِٱلْهَزْلِ","pageNumber":591,"juzNumber":30},{"id":86015,"surahNumber":86,"verseNumber":15,"arabicText":"إِنَّهُمْ يَكِيدُونَ كَيْدًا","pageNumber":591,"juzNumber":30},{"id":86016,"surahNumber":86,"verseNumber":16,"arabicText":"وَأَكِيدُ كَيْدًا","pageNumber":591,