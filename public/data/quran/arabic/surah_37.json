{"surahNumber":37,"verses":[{"id":37001,"surahNumber":37,"verseNumber":1,"arabicText":" وَٱلصَّـٰٓفَّـٰتِ صَفًّا","pageNumber":446,"juzNumber":23},{"id":37002,"surahNumber":37,"verseNumber":2,"arabicText":"فَٱلزَّٰجِرَٰتِ زَجْرًا","pageNumber":446,"juzNumber":23},{"id":37003,"surahNumber":37,"verseNumber":3,"arabicText":"فَٱلتَّـٰلِيَـٰتِ ذِكْرًا","pageNumber":446,"juzNumber":23},{"id":37004,"surahNumber":37,"verseNumber":4,"arabicText":"إِنَّ إِلَـٰهَكُمْ لَوَٰحِدٌ","pageNumber":446,"juzNumber":23},{"id":37005,"surahNumber":37,"verseNumber":5,"arabicText":"رَّبُّ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا وَرَبُّ ٱلْمَشَـٰرِقِ","pageNumber":446,"juzNumber":23},{"id":37006,"surahNumber":37,"verseNumber":6,"arabicText":"إِنَّا زَيَّنَّا ٱلسَّمَآءَ ٱلدُّنْيَا بِزِينَةٍ ٱلْكَوَاكِبِ","pageNumber":446,"juzNumber":23},{"id":37007,"surahNumber":37,"verseNumber":7,"arabicText":"وَحِفْظًا مِّن كُلِّ شَيْطَـٰنٍ مَّارِدٍ","pageNumber":446,"juzNumber":23},{"id":37008,"surahNumber":37,"verseNumber":8,"arabicText":"لَّا يَسَّمَّعُونَ إِلَى ٱلْمَلَإِ ٱلْأَعْلَىٰ وَيُقْذَفُونَ مِن كُلِّ جَانِبٍ","pageNumber":446,"juzNumber":23},{"id":37009,"surahNumber":37,"verseNumber":9,"arabicText":"دُحُورًا ۖ وَلَهُمْ عَذَابٌ وَاصِبٌ","pageNumber":446,"juzNumber":23},{"id":37010,"surahNumber":37,"verseNumber":10,"arabicText":"إِلَّا مَنْ خَطِفَ ٱلْخَطْفَةَ فَأَتْبَعَهُۥ شِهَابٌ ثَاقِبٌ","pageNumber":446,"juzNumber":23},{"id":37011,"surahNumber":37,"verseNumber":11,"arabicText":"فَٱسْتَفْتِهِمْ أَهُمْ أَشَدُّ خَلْقًا أَم مَّنْ خَلَقْنَآ ۚ إِنَّا خَلَقْنَـٰهُم مِّن طِينٍ لَّازِبٍۭ","pageNumber":446,"juzNumber":23},{"id":37012,"surahNumber":37,"verseNumber":12,"arabicText":"بَلْ عَجِبْتَ وَيَسْخَرُونَ","pageNumber":446,"juzNumber":23},{"id":37013,"surahNumber":37,"verseNumber":13,"arabicText":"وَإِذَا ذُكِّرُوا۟ لَا يَذْكُرُونَ","pageNumber":446,"juzNumber":23},{"id":37014,"surahNumber":37,"verseNumber":14,"arabicText":"وَإِذَا رَأَوْا۟ ءَايَةً يَسْتَسْخِرُونَ","pageNumber":446,"juzNumber":23