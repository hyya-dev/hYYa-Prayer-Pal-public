        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Переглядайте час своїх молитов з першого погляду"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنی نماز کے اوقات کو ایک نظر میں دیکھیں"
