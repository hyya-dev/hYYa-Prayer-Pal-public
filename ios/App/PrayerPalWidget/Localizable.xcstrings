    "configDescription": {
      "extractionState": "manual",
      "localizations": {
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "የጸሎት ጊዜዎችዎን በጨረፍታ ይመልከቱ"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اطلع على أوقات صلاتك بنظرة سريعة"
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "আপোনাৰ প্ৰাৰ্থনাৰ সময়বোৰ একেবাৰে চকুত পৰাকৈ চাওক"
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Namaz vaxtlarınıza bir baxışda baxın"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Вижте времената си за молитва с един поглед"
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "Aw ye aw ka delili waatiw lajɛ ɲɛ kelen na"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এক নজরে আপনার নামাজের সময় দেখুন"
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pregledajte vrijeme molitve na prvi pogled"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sehen Sie Ihre Gebetszeiten auf einen Blick"
          }
        },
        "dv": {
          "stringUnit": {
            "state": "translated",
            "value": "ނަމާދު ވަގުތުތައް އެއް ނަޒަރަކުން ބަލާށެވެ"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "View your prayer times at a glance"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vea sus tiempos de oración de un vistazo"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "مشاهده زمان نماز در یک نگاه"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Consultez vos horaires de prière en un coup d'œil"
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "તમારા પ્રાર્થનાના સમયને એક નજરમાં જુઓ"
          }
        },
        "ha": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalli lokutan addu'o'inku da kallo"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "צפה בזמני התפילה שלך במבט חטוף"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपनी प्रार्थना के समय को एक नज़र में देखें"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Lihat jadwal waktu sholat Anda secara sekilas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Visualizza i tuoi orari di preghiera a colpo d'occhio"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "祈りの時間を一目で確認"
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Намаз уақыттарын бір шолуда қараңыз"
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "មើលពេលវេលាអធិស្ឋានរបស់អ្នកដោយសង្ខេប"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기도 시간을 한눈에 확인하세요"
          }
        },
        "ku": {
          "stringUnit": {
            "state": "translated",
            "value": "Demên nimêja xwe bi çavekî bibînin"
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "നിങ്ങളുടെ പ്രാർത്ഥന സമയങ്ങൾ ഒറ്റനോട്ടത്തിൽ കാണുക"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "तुमच्या प्रार्थनेच्या वेळा एका नजरेत पहा"
          }
        },
        "mrw": {
          "stringUnit": {
            "state": "translated",
            "value": "Tingnan ang iyong mga oras ng panalangin sa isang sulyap"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Lihat waktu solat anda sepintas lalu"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "आफ्नो प्रार्थना समय एक नजरमा हेर्नुहोस्"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bekijk in één oogopslag uw gebedstijden"
          }
        },
        "om": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeroo kadhannaa keessan ija tokkoon ilaalaa"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przeglądaj swoje godziny modlitwy na pierwszy rzut oka"
          }
        },
        "prs": {
          "stringUnit": {
            "state": "translated",
            "value": "مشاهده زمان نماز در یک نگاه"
          }
        },
        "ps": {
          "stringUnit": {
            "state": "translated",
            "value": "د لمانځه وختونه په لنډه توګه وګورئ"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja seus horários de oração num relance."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Vizualizați-vă orele de rugăciune dintr-o privire"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Просматривайте время своих молитв с первого взгляда."
          }
        },
        "rw": {
          "stringUnit": {
            "state": "translated",
            "value": "Reba amasaha yawe yo gusenga mu buryo burambuye"
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "پنهنجي نماز جي وقتن کي هڪ نظر ۾ ڏسو"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "ඔබගේ යාච්ඤා වේලාවන් එක බැල්මකින් බලන්න"
          }
        },
        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "Waqtiyadaada salaadda eeg muuqaal ahaan"
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Shikoni kohët tuaja të lutjes me një shikim"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Se dina bönetider med en snabb blick"
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Tazama nyakati zako za maombi kwa muhtasari"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் பிரார்த்தனை நேரங்களை ஒரே பார்வையில் காண்க"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ ప్రార్థన సమయాలను ఒక చూపులో వీక్షించండి"
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Вақтҳои намози худро дар як нигоҳ бубинед"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ดูเวลาละหมาดของคุณได้อย่างรวดเร็ว"
