    "NSLocationAlwaysAndWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location Always and When In Use Usage Description",
      "localizations" : {
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "hYYa Prayer Pal (Source) ትክክለኛ የጸሎት ጊዜዎችን ለማስላት እና መግብርዎን ለማዘመን አካባቢዎን ይፈልጋል።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحتاج تطبيق hYYa Prayer Pal (Source) إلى موقعك لحساب أوقات الصلاة بدقة وتحديث الأداة."
          }
        },
        "as" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "hYYa প্ৰাৰ্থনা পালক সঠিক প্ৰাৰ্থনাৰ সময় গণনা কৰিবলৈ আৰু আপোনাৰ ৱিজেট আপডেট কৰিবলৈ আপোনাৰ অৱস্থানৰ প্ৰয়োজন।"
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "hYYa Prayer Pal (Source) dəqiq namaz vaxtlarını hesablamaq və vidjetinizi yeniləmək üçün yerinizi tələb edir."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "hYYa Prayer Pal (Source) се нуждае от вашето местоположение, за да изчисли точните времена за молитва и да актуализира вашия уиджет."
          }
        },
        "bm" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "hYYa Prayer Pal (Source) mago bɛ i sigiyɔrɔ la walasa ka delili waati tigitigiw jate ani ka i ka wideyo kura."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "সঠিক নামাজের সময় গণনা করতে ও আপনার উইজেট আপডেট করতে hYYa Prayer Pal (Source)-এর আপনার অবস্থান প্রয়োজন।"
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "hYYa Prayer Pal (Source) treba vašu lokaciju kako bi izračunao tačno vrijeme molitve i ažurirao vaš widget."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "hYYa Prayer Pal (Source) benötigt Ihren Standort, um genaue Gebetszeiten zu berechnen und Ihr Widget zu aktualisieren."
          }
        },
        "dv" : {
          "stringUnit" : {
            "state" : "translated",
