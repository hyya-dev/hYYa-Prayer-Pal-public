{"surahNumber":103,"verses":[{"id":103001,"surahNumber":103,"verseNumber":1,"arabicText":" وَٱلْعَصْرِ","pageNumber":601,"juzNumber":30},{"id":103002,"surahNumber":103,"verseNumber":2,"arabicText":"إِنَّ ٱلْإِنسَـٰنَ لَفِى خُسْرٍ","pageNumber":601,"juzNumber":30},{"id":103003,"surahNumber":103,"verseNumber":3,"arabicText":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ وَتَوَاصَوْا۟ بِٱلْحَقِّ وَتَوَاصَوْا۟ بِٱلصَّبْرِ","pageNumber":601,"juzNumber":30}]}