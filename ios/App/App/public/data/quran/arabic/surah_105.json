{"surahNumber":105,"verses":[{"id":105001,"surahNumber":105,"verseNumber":1,"arabicText":" أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَـٰبِ ٱلْفِيلِ","pageNumber":601,"juzNumber":30},{"id":105002,"surahNumber":105,"verseNumber":2,"arabicText":"أَلَمْ يَجْعَلْ كَيْدَهُمْ فِى تَضْلِيلٍ","pageNumber":601,"juzNumber":30},{"id":105003,"surahNumber":105,"verseNumber":3,"arabicText":"وَأَرْسَلَ عَلَيْهِمْ طَيْرًا أَبَابِيلَ","pageNumber":601,"juzNumber":30},{"id":105004,"surahNumber":105,"verseNumber":4,"arabicText":"تَرْمِيهِم بِحِجَارَةٍ مِّن سِجِّيلٍ","pageNumber":601,"juzNumber":30},{"id":105005,"surahNumber":105,"verseNumber":5,"arabicText":"فَجَعَلَهُمْ كَعَصْفٍ مَّأْكُولٍۭ","pageNumber":601,"juzNumber":30}]}