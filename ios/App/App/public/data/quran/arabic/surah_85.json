{"surahNumber":85,"verses":[{"id":85001,"surahNumber":85,"verseNumber":1,"arabicText":" وَٱلسَّمَآءِ ذَاتِ ٱلْبُرُوجِ","pageNumber":590,"juzNumber":30},{"id":85002,"surahNumber":85,"verseNumber":2,"arabicText":"وَٱلْيَوْمِ ٱلْمَوْعُودِ","pageNumber":590,"juzNumber":30},{"id":85003,"surahNumber":85,"verseNumber":3,"arabicText":"وَشَاهِدٍ وَمَشْهُودٍ","pageNumber":590,"juzNumber":30},{"id":85004,"surahNumber":85,"verseNumber":4,"arabicText":"قُتِلَ أَصْحَـٰبُ ٱلْأُخْدُودِ","pageNumber":590,"juzNumber":30},{"id":85005,"surahNumber":85,"verseNumber":5,"arabicText":"ٱلنَّارِ ذَاتِ ٱلْوَقُودِ","pageNumber":590,"juzNumber":30},{"id":85006,"surahNumber":85,"verseNumber":6,"arabicText":"إِذْ هُمْ عَلَيْهَا قُعُودٌ","pageNumber":590,"juzNumber":30},{"id":85007,"surahNumber":85,"verseNumber":7,"arabicText":"وَهُمْ عَلَىٰ مَا يَفْعَلُونَ بِٱلْمُؤْمِنِينَ شُهُودٌ","pageNumber":590,"juzNumber":30},{"id":85008,"surahNumber":85,"verseNumber":8,"arabicText":"وَمَا نَقَمُوا۟ مِنْهُمْ إِلَّآ أَن يُؤْمِنُوا۟ بِٱللَّهِ ٱلْعَزِيزِ ٱلْحَمِيدِ","pageNumber":590,"juzNumber":30},{"id":85009,"surahNumber":85,"verseNumber":9,"arabicText":"ٱلَّذِى لَهُۥ مُلْكُ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ ۚ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍ شَهِيدٌ","pageNumber":590,"juzNumber":30},{"id":85010,"surahNumber":85,"verseNumber":10,"arabicText":"إِنَّ ٱلَّذِينَ فَتَنُوا۟ ٱلْمُؤْمِنِينَ وَٱلْمُؤْمِنَـٰتِ ثُمَّ لَمْ يَتُوبُوا۟ فَلَهُمْ عَذَابُ جَهَنَّمَ وَلَهُمْ عَذَابُ ٱلْحَرِيقِ","pageNumber":590,"juzNumber":30},{"id":85011,"surahNumber":85,"verseNumber":11,"arabicText":"إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ لَهُمْ جَنَّـٰتٌ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَـٰرُ ۚ ذَٰلِكَ ٱلْفَوْزُ ٱلْكَبِيرُ","pageNumber":590,"juzNumber":30},{"id":85012,"surahNumber":85,"verseNumber":12,"arabicText":"إِنَّ بَطْشَ رَبِّكَ لَشَدِيدٌ","pageNumber":590,"juzNumber":30},{"id":85013,"surahNumber":85,"verseNumber":13,"arabicText":"إِنَّهُۥ هُوَ يُبْدِئُ وَيُعِيدُ","pageNumber":590,"juzNumber":30},{"id":85014,"surahNumber":85,"verseNumber":14,"arabicText":"وَهُوَ ٱلْغَفُورُ ٱلْوَدُودُ","pageNumber":590,"juzNumber":30},{"id":85015,"surahNumber":85,"verseNumber":15,"arabicText":"ذُو ٱلْعَرْشِ ٱلْمَجِيدُ","pageNumber":590,"juzNumber":30},{"id":85016,"surahNumber":85,"verseNumber":16,"arabicText":"فَعَّالٌ لِّمَا يُرِيدُ","pageNumber":590,"juzNumber":30},{"id":85017,"surahNumber":85,"verseNumber":17,"arabicText":"هَلْ أَتَىٰكَ حَدِيثُ ٱلْجُنُودِ","pageNumber":590,"juzNumber":30},{"id":85018,"surahNumber":85,"verseNumber":18,"arabicText":"فِرْعَوْنَ وَثَمُودَ","pageNumber":590,"juzNumber":30},{"id":85019,"surahNumber":85,"verseNumber":19,"arabicText":"بَلِ ٱلَّذِينَ كَفَرُوا۟ فِى تَكْذِيبٍ","pageNumber":590,"juzNumber":30},{"id":85020,"surahNumber":85,"verseNumber":20,"arabicText":"وَٱللَّهُ مِن وَرَآئِهِم مُّحِيطٌۢ","pageNumber":590,"juzNumber":30},{"id":85021,"surahNumber":85,"verseNumber":21,"arabicText":"بَلْ هُوَ قُرْءَانٌ مَّجِيدٌ","pageNumber":590,"juzNumber":30},{"id":85022,"surahNumber":85,"verseNumber":22,"arabicText":"فِى لَوْحٍ مَّحْفُوظٍۭ","pageNumber":590,"juzNumber":30}]}