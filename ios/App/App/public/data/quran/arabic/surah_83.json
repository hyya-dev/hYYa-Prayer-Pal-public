{"surahNumber":83,"verses":[{"id":83001,"surahNumber":83,"verseNumber":1,"arabicText":" وَيْلٌ لِّلْمُطَفِّفِينَ","pageNumber":587,"juzNumber":30},{"id":83002,"surahNumber":83,"verseNumber":2,"arabicText":"ٱلَّذِينَ إِذَا ٱكْتَالُوا۟ عَلَى ٱلنَّاسِ يَسْتَوْفُونَ","pageNumber":587,"juzNumber":30},{"id":83003,"surahNumber":83,"verseNumber":3,"arabicText":"وَإِذَا كَالُوهُمْ أَو وَّزَنُوهُمْ يُخْسِرُونَ","pageNumber":587,"juzNumber":30},{"id":83004,"surahNumber":83,"verseNumber":4,"arabicText":"أَلَا يَظُنُّ أُو۟لَـٰٓئِكَ أَنَّهُم مَّبْعُوثُونَ","pageNumber":587,"juzNumber":30},{"id":83005,"surahNumber":83,"verseNumber":5,"arabicText":"لِيَوْمٍ عَظِيمٍ","pageNumber":587,"juzNumber":30},{"id":83006,"surahNumber":83,"verseNumber":6,"arabicText":"يَوْمَ يَقُومُ ٱلنَّاسُ لِرَبِّ ٱلْعَـٰلَمِينَ","pageNumber":587,"juzNumber":30},{"id":83007,"surahNumber":83,"verseNumber":7,"arabicText":"كَلَّآ إِنَّ كِتَـٰبَ ٱلْفُجَّارِ لَفِى سِجِّينٍ","pageNumber":588,"juzNumber":30},{"id":83008,"surahNumber":83,"verseNumber":8,"arabicText":"وَمَآ أَدْرَىٰكَ مَا سِجِّينٌ","pageNumber":588,"juzNumber":30},{"id":83009,"surahNumber":83,"verseNumber":9,"arabicText":"كِتَـٰبٌ مَّرْقُومٌ","pageNumber":588,"juzNumber":30},{"id":83010,"surahNumber":83,"verseNumber":10,"arabicText":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ","pageNumber":588,"juzNumber":30},{"id":83011,"surahNumber":83,"verseNumber":11,"arabicText":"ٱلَّذِينَ يُكَذِّبُونَ بِيَوْمِ ٱلدِّينِ","pageNumber":588,"juzNumber":30},{"id":83012,"surahNumber":83,"verseNumber":12,"arabicText":"وَمَا يُكَذِّبُ بِهِۦٓ إِلَّا كُلُّ مُعْتَدٍ أَثِيمٍ","pageNumber":588,"juzNumber":30},{"id":83013,"surahNumber":83,"verseNumber":13,"arabicText":"إِذَا تُتْلَىٰ عَلَيْهِ ءَايَـٰتُنَا قَالَ أَسَـٰطِيرُ ٱلْأَوَّلِينَ","pageNumber":588,"juzNumber":30},{"id":83014,"surahNumber":83,"verseNumber":14,"arabicText":"كَلَّا ۖ بَلْ ۜ رَانَ عَلَىٰ قُلُوبِهِم مَّا كَانُوا۟ يَكْسِبُونَ","pageNumber":588,"juzNumber":30},{"id":83015,"surahNumber":83,"verseNumber":15,"arabicText":"كَلَّآ إِنَّهُمْ عَن رَّبِّهِمْ يَوْمَئِذٍ لَّمَحْجُوبُونَ","pageNumber":588,"juzNumber":30},{"id":83016,"surahNumber":83,"verseNumber":16,"arabicText":"ثُمَّ إِنَّهُمْ لَصَالُوا۟ ٱلْجَحِيمِ","pageNumber":588,"juzNumber":30},{"id":83017,"surahNumber":83,"verseNumber":17,"arabicText":"ثُمَّ يُقَالُ هَـٰذَا ٱلَّذِى كُنتُم بِهِۦ تُكَذِّبُونَ","pageNumber":588,"juzNumber":30},{"id":83018,"surahNumber":83,"verseNumber":18,"arabicText":"كَلَّآ إِنَّ كِتَـٰبَ ٱلْأَبْرَارِ لَفِى عِلِّيِّينَ","pageNumber":588,"juzNumber":30},{"id":83019,"surahNumber":83,"verseNumber":19,"arabicText":"وَمَآ أَدْرَىٰكَ مَا عِلِّيُّونَ","pageNumber":588,"juzNumber":30},{"id":83020,"surahNumber":83,"verseNumber":20,"arabicText":"كِتَـٰبٌ مَّرْقُومٌ","pageNumber":588,"juzNumber":30},{"id":83021,"surahNumber":83,"verseNumber":21,"arabicText":"يَشْهَدُهُ ٱلْمُقَرَّبُونَ","pageNumber":588,"juzNumber":30},{"id":83022,"surahNumber":83,"verseNumber":22,"arabicText":"إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍ","pageNumber":588,"juzNumber":30},{"id":83023,"surahNumber":83,"verseNumber":23,"arabicText":"عَلَى ٱلْأَرَآئِكِ يَنظُرُونَ","pageNumber":588,"juzNumber":30},{"id":83024,"surahNumber":83,"verseNumber":24,"arabicText":"تَعْرِفُ فِى وُجُوهِهِمْ نَضْرَةَ ٱلنَّعِيمِ","pageNumber":588,"juzNumber":30},{"id":83025,"surahNumber":83,"verseNumber":25,"arabicText":"يُسْقَوْنَ مِن رَّحِيقٍ مَّخْتُومٍ","pageNumber":588,"juzNumber":30},{"id":83026,"surahNumber":83,"verseNumber":26,"arabicText":"خِتَـٰمُهُۥ مِسْكٌ ۚ وَفِى ذَٰلِكَ فَلْيَتَنَافَسِ ٱلْمُتَنَـٰفِسُونَ","pageNumber":588,"juzNumber":30},{"id":83027,"surahNumber":83,"verseNumber":27,"arabicText":"وَمِزَاجُهُۥ مِن تَسْنِيمٍ","pageNumber":588,"juzNumber":30},{"id":83028,"surahNumber":83,"verseNumber":28,"arabicText":"عَيْنًا يَشْرَبُ بِهَا ٱلْمُقَرَّبُونَ","pageNumber":588,"juzNumber":30},{"id":83029,"surahNumber":83,"verseNumber":29,"arabicText":"إِنَّ ٱلَّذِينَ أَجْرَمُوا۟ كَانُوا۟ مِنَ ٱلَّذِينَ ءَامَنُوا۟ يَضْحَكُونَ","pageNumber":588,"juzNumber":30},{"id":83030,"surahNumber":83,"verseNumber":30,"arabicText":"وَإِذَا مَرُّوا۟ بِهِمْ يَتَغَامَزُونَ","pageNumber":588,"juzNumber":30},{"id":83031,"surahNumber":83,"verseNumber":31,"arabicText":"وَإِذَا ٱنقَلَبُوٓا۟ إِلَىٰٓ أَهْلِهِمُ ٱنقَلَبُوا۟ فَكِهِينَ","pageNumber":588,"juzNumber":30},{"id":83032,"surahNumber":83,"verseNumber":32,"arabicText":"وَإِذَا رَأَوْهُمْ قَالُوٓا۟ إِنَّ هَـٰٓؤُلَآءِ لَضَآلُّونَ","pageNumber":588,"juzNumber":30},{"id":83033,"surahNumber":83,"verseNumber":33,"arabicText":"وَمَآ أُرْسِلُوا۟ عَلَيْهِمْ حَـٰفِظِينَ","pageNumber":588,"juzNumber":30},{"id":83034,"surahNumber":83,"verseNumber":34,"arabicText":"فَٱلْيَوْمَ ٱلَّذِينَ ءَامَنُوا۟ مِنَ ٱلْكُفَّارِ يَضْحَكُونَ","pageNumber":588,"juzNumber":30},{"id":83035,"surahNumber":83,"verseNumber":35,"arabicText":"عَلَى ٱلْأَرَآئِكِ يَنظُرُونَ","pageNumber":589,"juzNumber":30},{"id":83036,"surahNumber":83,"verseNumber":36,"arabicText":"هَلْ ثُوِّبَ ٱلْكُفَّارُ مَا كَانُوا۟ يَفْعَلُونَ","pageNumber":589,"juzNumber":30}]}