{"surahNumber":104,"verses":[{"id":104001,"surahNumber":104,"verseNumber":1,"arabicText":" وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ","pageNumber":601,"juzNumber":30},{"id":104002,"surahNumber":104,"verseNumber":2,"arabicText":"ٱلَّذِى جَمَعَ مَالًا وَعَدَّدَهُۥ","pageNumber":601,"juzNumber":30},{"id":104003,"surahNumber":104,"verseNumber":3,"arabicText":"يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ","pageNumber":601,"juzNumber":30},{"id":104004,"surahNumber":104,"verseNumber":4,"arabicText":"كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ","pageNumber":601,"juzNumber":30},{"id":104005,"surahNumber":104,"verseNumber":5,"arabicText":"وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ","pageNumber":601,"juzNumber":30},{"id":104006,"surahNumber":104,"verseNumber":6,"arabicText":"نَارُ ٱللَّهِ ٱلْمُوقَدَةُ","pageNumber":601,"juzNumber":30},{"id":104007,"surahNumber":104,"verseNumber":7,"arabicText":"ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ","pageNumber":601,"juzNumber":30},{"id":104008,"surahNumber":104,"verseNumber":8,"arabicText":"إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ","pageNumber":601,"juzNumber":30},{"id":104009,"surahNumber":104,"verseNumber":9,"arabicText":"فِى عَمَدٍ مُّمَدَّدَةٍۭ","pageNumber":601,"juzNumber":30}]}