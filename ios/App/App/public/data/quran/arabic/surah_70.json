{"surahNumber":70,"verses":[{"id":70001,"surahNumber":70,"verseNumber":1,"arabicText":" سَأَلَ سَآئِلٌۢ بِعَذَابٍ وَاقِعٍ","pageNumber":568,"juzNumber":29},{"id":70002,"surahNumber":70,"verseNumber":2,"arabicText":"لِّلْكَـٰفِرِينَ لَيْسَ لَهُۥ دَافِعٌ","pageNumber":568,"juzNumber":29},{"id":70003,"surahNumber":70,"verseNumber":3,"arabicText":"مِّنَ ٱللَّهِ ذِى ٱلْمَعَارِجِ","pageNumber":568,"juzNumber":29},{"id":70004,"surahNumber":70,"verseNumber":4,"arabicText":"تَعْرُجُ ٱلْمَلَـٰٓئِكَةُ وَٱلرُّوحُ إِلَيْهِ فِى يَوْمٍ كَانَ مِقْدَارُهُۥ خَمْسِينَ أَلْفَ سَنَةٍ","pageNumber":568,"juzNumber":29},{"id":70005,"surahNumber":70,"verseNumber":5,"arabicText":"فَٱصْبِرْ صَبْرًا جَمِيلًا","pageNumber":568,"juzNumber":29},{"id":70006,"surahNumber":70,"verseNumber":6,"arabicText":"إِنَّهُمْ يَرَوْنَهُۥ بَعِيدًا","pageNumber":568,"juzNumber":29},{"id":70007,"surahNumber":70,"verseNumber":7,"arabicText":"وَنَرَىٰهُ قَرِيبًا","pageNumber":568,"juzNumber":29},{"id":70008,"surahNumber":70,"verseNumber":8,"arabicText":"يَوْمَ تَكُونُ ٱلسَّمَآءُ كَٱلْمُهْلِ","pageNumber":568,"juzNumber":29},{"id":70009,"surahNumber":70,"verseNumber":9,"arabicText":"وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ","pageNumber":568,"juzNumber":29},{"id":70010,"surahNumber":70,"verseNumber":10,"arabicText":"وَلَا يَسْـَٔلُ حَمِيمٌ حَمِيمًا","pageNumber":568,"juzNumber":29},{"id":70011,"surahNumber":70,"verseNumber":11,"arabicText":"يُبَصَّرُونَهُمْ ۚ يَوَدُّ ٱلْمُجْرِمُ لَوْ يَفْتَدِى مِنْ عَذَابِ يَوْمِئِذٍۭ بِبَنِيهِ","pageNumber":569,"juzNumber":29},{"id":70012,"surahNumber":70,"verseNumber":12,"arabicText":"وَصَـٰحِبَتِهِۦ وَأَخِيهِ","pageNumber":569,"juzNumber":29},{"id":70013,"surahNumber":70,"verseNumber":13,"arabicText":"وَفَصِيلَتِهِ ٱلَّتِى تُـْٔوِيهِ","pageNumber":569,"juzNumber":29},{"id":70014,"surahNumber":70,"verseNumber":14,"arabicText":"وَمَن فِى ٱلْأَرْضِ جَمِيعًا ثُمَّ يُنجِيهِ","pageNumber":569,"juzNumber":29},{"id":70015,"surahNumber":70,"verseNumber":15,"arabicText":"كَلَّآ ۖ إِنَّهَا لَظَىٰ","pageNumber":569,"juzNumber":29},{"id":70016,"surahNumber":70,"verseNumber":16,"arabicText":"نَزَّاعَةً لِّلشَّوَىٰ","pageNumber":569,"juzNumber":29},{"id":70017,"surahNumber":70,"verseNumber":17,"arabicText":"تَدْعُوا۟ مَنْ أَدْبَرَ وَتَوَلَّىٰ","pageNumber":569,"juzNumber":29},{"id":70018,"surahNumber":70,"verseNumber":18,"arabicText":"وَجَمَعَ فَأَوْعَىٰٓ","pageNumber":569,"juzNumber":29},{"id":70019,"surahNumber":70,"verseNumber":19,"arabicText":"۞ إِنَّ ٱلْإِنسَـٰنَ خُلِقَ هَلُوعًا","pageNumber":569,"juzNumber":29},{"id":70020,"surahNumber":70,"verseNumber":20,"arabicText":"إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعًا","pageNumber":569,"juzNumber":29},{"id":70021,"surahNumber":70,"verseNumber":21,"arabicText":"وَإِذَا مَسَّهُ ٱلْخَيْرُ مَنُوعًا","pageNumber":569,"juzNumber":29},{"id":70022,"surahNumber":70,"verseNumber":22,"arabicText":"إِلَّا ٱلْمُصَلِّينَ","pageNumber":569,"juzNumber":29},{"id":70023,"surahNumber":70,"verseNumber":23,"arabicText":"ٱلَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ دَآئِمُونَ","pageNumber":569,"juzNumber":29},{"id":70024,"surahNumber":70,"verseNumber":24,"arabicText":"وَٱلَّذِينَ فِىٓ أَمْوَٰلِهِمْ حَقٌّ مَّعْلُومٌ","pageNumber":569,"juzNumber":29},{"id":70025,"surahNumber":70,"verseNumber":25,"arabicText":"لِّلسَّآئِلِ وَٱلْمَحْرُومِ","pageNumber":569,"juzNumber":29},{"id":70026,"surahNumber":70,"verseNumber":26,"arabicText":"وَٱلَّذِينَ يُصَدِّقُونَ بِيَوْمِ ٱلدِّينِ","pageNumber":569,"juzNumber":29},{"id":70027,"surahNumber":70,"verseNumber":27,"arabicText":"وَٱلَّذِينَ هُم مِّنْ عَذَابِ رَبِّهِم مُّشْفِقُونَ","pageNumber":569,"juzNumber":29},{"id":70028,"surahNumber":70,"verseNumber":28,"arabicText":"إِنَّ عَذَابَ رَبِّهِمْ غَيْرُ مَأْمُونٍ","pageNumber":569,"juzNumber":29},{"id":70029,"surahNumber":70,"verseNumber":29,"arabicText":"وَٱلَّذِينَ هُمْ لِفُرُوجِهِمْ حَـٰفِظُونَ","pageNumber":569,"juzNumber":29},{"id":70030,"surahNumber":70,"verseNumber":30,"arabicText":"إِلَّا عَلَىٰٓ أَزْوَٰجِهِمْ أَوْ مَا مَلَكَتْ أَيْمَـٰنُهُمْ فَإِنَّهُمْ غَيْرُ مَلُومِينَ","pageNumber":569,"juzNumber":29},{"id":70031,"surahNumber":70,"verseNumber":31,"arabicText":"فَمَنِ ٱبْتَغَىٰ وَرَآءَ ذَٰلِكَ فَأُو۟لَـٰٓئِكَ هُمُ ٱلْعَادُونَ","pageNumber":569,"juzNumber":29},{"id":70032,"surahNumber":70,"verseNumber":32,"arabicText":"وَٱلَّذِينَ هُمْ لِأَمَـٰنَـٰتِهِمْ وَعَهْدِهِمْ رَٰعُونَ","pageNumber":569,"juzNumber":29},{"id":70033,"surahNumber":70,"verseNumber":33,"arabicText":"وَٱلَّذِينَ هُم بِشَهَـٰدَٰتِهِمْ قَآئِمُونَ","pageNumber":569,"juzNumber":29},{"id":70034,"surahNumber":70,"verseNumber":34,"arabicText":"وَٱلَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ يُحَافِظُونَ","pageNumber":569,"juzNumber":29},{"id":70035,"surahNumber":70,"verseNumber":35,"arabicText":"أُو۟لَـٰٓئِكَ فِى جَنَّـٰتٍ مُّكْرَمُونَ","pageNumber":569,"juzNumber":29},{"id":70036,"surahNumber":70,"verseNumber":36,"arabicText":"فَمَالِ ٱلَّذِينَ كَفَرُوا۟ قِبَلَكَ مُهْطِعِينَ","pageNumber":569,"juzNumber":29},{"id":70037,"surahNumber":70,"verseNumber":37,"arabicText":"عَنِ ٱلْيَمِينِ وَعَنِ ٱلشِّمَالِ عِزِينَ","pageNumber":569,"juzNumber":29},{"id":70038,"surahNumber":70,"verseNumber":38,"arabicText":"أَيَطْمَعُ كُلُّ ٱمْرِئٍ مِّنْهُمْ أَن يُدْخَلَ جَنَّةَ نَعِيمٍ","pageNumber":569,"juzNumber":29},{"id":70039,"surahNumber":70,"verseNumber":39,"arabicText":"كَلَّآ ۖ إِنَّا خَلَقْنَـٰهُم مِّمَّا يَعْلَمُونَ","pageNumber":569,"juzNumber":29},{"id":70040,"surahNumber":70,"verseNumber":40,"arabicText":"فَلَآ أُقْسِمُ بِرَبِّ ٱلْمَشَـٰرِقِ وَٱلْمَغَـٰرِبِ إِنَّا لَقَـٰدِرُونَ","pageNumber":570,"juzNumber":29},{"id":70041,"surahNumber":70,"verseNumber":41,"arabicText":"عَلَىٰٓ أَن نُّبَدِّلَ خَيْرًا مِّنْهُمْ وَمَا نَحْنُ بِمَسْبُوقِينَ","pageNumber":570,"juzNumber":29},{"id":70042,"surahNumber":70,"verseNumber":42,"arabicText":"فَذَرْهُمْ يَخُوضُوا۟ وَيَلْعَبُوا۟ حَتَّىٰ يُلَـٰقُوا۟ يَوْمَهُمُ ٱلَّذِى يُوعَدُونَ","pageNumber":570,"juzNumber":29},{"id":70043,"surahNumber":70,"verseNumber":43,"arabicText":"يَوْمَ يَخْرُجُونَ مِنَ ٱلْأَجْدَاثِ سِرَاعًا كَأَنَّهُمْ إِلَىٰ نُصُبٍ يُوفِضُونَ","pageNumber":570,"juzNumber":29},{"id":70044,"surahNumber":70,"verseNumber":44,"arabicText":"خَـٰشِعَةً أَبْصَـٰرُهُمْ تَرْهَقُهُمْ ذِلَّةٌ ۚ ذَٰلِكَ ٱلْيَوْمُ ٱلَّذِى كَانُوا۟ يُوعَدُونَ","pageNumber":570,"juzNumber":29}]}