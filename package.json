{
  "name": "prayerpal",
  "private": true,
  "version": "3.3.0",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/qa-mushaf-db.cjs && node scripts/qa-quran-translations.cjs && node scripts/qa-quran-audio-sync-reciters.cjs && node scripts/qa-manasik.cjs && node scripts/generate-xcstrings.cjs && node scripts/qa-ios-widget-watch-localizable-xcstrings.cjs && node scripts/qa-bundled-assets.cjs && node scripts/qa-tafsir-coverage.cjs",
    "build:mushaf-db": "node scripts/build-mushaf-db.cjs",
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "cleanup:dv": "node scripts/cleanup-dv-locale.mjs",
    "qa:localization": "node scripts/qa-localization-integrity.cjs",
    "qa:assets": "node scripts/qa-bundled-assets.cjs",
    "qa:tafsir": "node scripts/qa-tafsir-coverage.cjs",
    "qa:title-phonetics": "node scripts/qa-app-title-phonetics.mjs",
    "qa:title-phonetics:fix": "node scripts/qa-app-title-phonetics.mjs --fix",
    "validate:title-unicode": "node scripts/validate-app-title-unicode.mjs",
    "validate:title-unicode:strict": "node scripts/validate-app-title-unicode.mjs --strict",
    "generate:ios-titles": "node scripts/generate-ios-infoplist-xcstrings.cjs",
    "asc:fetch-listings": "node scripts/fetch-app-store-listing-localizations.mjs",
    "asc:localize:dry": "node scripts/asc-localize-store-listing.mjs --version 3.3.0 --dry-run",
    "asc:localize:apply": "node scripts/asc-localize-store-listing.mjs --version 3.3.0 --apply",
    "asc:localize:dry:new-locales": "node scripts/asc-localize-store-listing.mjs --version 3.3.0 --dry-run --include-new-locales",
    "asc:localize:apply:new-locales": "node scripts/asc-localize-store-listing.mjs --version 3.3.0 --apply --include-new-locales",
    "asc:localize:apply:all-except-bn-ur": "node scripts/asc-localize-store-listing.mjs --version 3.3.0 --apply --include-new-locales --skip-locales bn,ur",
    "asc:appname:apply:all-except-bn-ur": "node scripts/asc-localize-store-listing.mjs --version 3.3.0 --apply --include-new-locales --skip-locales bn,ur --app-info-names",
    "asc:privacy:dry": "node scripts/asc-localize-store-listing.mjs --version 3.3.0 --dry-run --privacy-only",
    "asc:privacy:apply": "node scripts/asc-localize-store-listing.mjs --version 3.3.0 --apply --privacy-only",
    "asc:export:bn-ur": "node scripts/asc-localize-store-listing.mjs --version 3.3.0 --dry-run --export artifacts/appstore/3.3.0 --locales bn,ur",
    "asc:qa:no-fallbacks": "node scripts/qa-asc-metadata-no-fallbacks.mjs app-store-listings.current.json",
    "asc:export:paste-files": "node scripts/generate-appstoreconnect-paste-files.mjs --export app-store-listings.after4.json --version 3.3.0 --outdir AppStoreConnect/3.3.0",
    "asc:subtitle:localize": "node scripts/update-appstore-subtitle-localized.mjs --dir AppStoreConnect/3.3.0",
    "localize:missing-ui": "node scripts/translate-missing-ui-keys.cjs",
    "i18n:fill-verse-number-placeholder": "node scripts/fill-library-tafsir-verse-number-placeholder.cjs",
    "postinstall": "bash scripts/patch-capacitor.sh",
    "sync": "npm run build && npx cap sync",
    "sync:ios": "npm run build && npx cap sync ios",
    "sync:android": "npm run build && npx cap sync android",
    "sync:ios:dev": "npm run build:dev && npx cap sync ios",
    "lint": "eslint .",
    "test": "vitest",
    "test:ci": "vitest run"
  },
  "dependencies": {
    "@capacitor-community/in-app-review": "^8.0.0",
    "@capacitor/android": "^8.0.1",
    "@capacitor/browser": "^8.0.0",
    "@capacitor/core": "^8.0.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.0.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.0.1",
    "@capacitor/local-notifications": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@quranjs/api": "^2.1.0",
    "adhan": "^4.4.3",
    "clsx": "^2.1.1",
    "dompurify": "^3.0.0",
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.562.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.2",
    "react-router-dom": "^7.0.0",
    "react-virtuoso": "^4.12.0",
    "sonner": "^2.0.7",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "which-country": "^1.0.0"
  },
  "devDependencies": {
    "@apideck/better-ajv-errors": "^0.3.3",
    "@capacitor/cli": "^8.0.0",
    "@eslint/js": "^9.32.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.0",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.21",
    "common-tags": "^1.8.2",
    "dotenv": "^16.6.1",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "glob": "^13.0.2",
    "globals": "^15.15.0",
    "happy-dom": "^20.8.9",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.3.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
